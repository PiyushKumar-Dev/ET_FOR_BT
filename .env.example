# Industrial Guardian AI — Environment Variables
# Copy this to .env and fill in your API keys

# ── LLM API Keys (optional — system falls back to rule-based if not set) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Agent URLs (for local dev without Docker) ─────────────────────────────────
SCADA_AGENT_URL=http://localhost:8001
IOT_AGENT_URL=http://localhost:8002
VISION_AGENT_URL=http://localhost:8003
PERMIT_AGENT_URL=http://localhost:8004
MASTER_AGENT_URL=http://localhost:8005

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3000
MONGODB_URI=mongodb://localhost:27017/industrial_guardian
DEV_MOCK_MODE=false

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3000
